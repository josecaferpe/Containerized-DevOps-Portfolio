# --- CREDENCIALES TELEGRAM ---
TELEGRAM_TOKEN=pon_aqui_tu_token
TELEGRAM_CHAT_ID=pon_aqui_tu_id

# --- AMADEUS API (OAUTH2) ---
# Regístrate en https://developers.amadeus.com/ para obtenerlas
AMADEUS_CLIENT_ID=tu_client_id_de_amadeus
AMADEUS_CLIENT_SECRET=tu_client_secret_de_amadeus

# --- CONFIGURACIÓN DEL VIAJE ---
# Códigos IATA (ej: MAD = Madrid, JFK = Nueva York, TYO = Tokyo)
ORIGIN=MAD
DESTINATION=JFK

# Fecha de salida (Formato AAAA-MM-DD)
DEPARTURE_DATE=2024-12-25

# --- ALERTA DE PRECIO ---
# El bot solo notificará si encuentra un vuelo por DEBAJO de este precio (Euros)
MAX_PRICE=600
